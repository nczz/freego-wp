#: includes/class-admin.php:134
msgid "This dashboard connects automatic repair, authoring guardrails, semantic review, and Freego-oriented rule tracking."
msgstr "此儀表板串接自動修補、編輯防護、語意審查與 Freego 規則追蹤。"

#: includes/class-admin.php:144
msgid "Scan"
msgstr "掃描"

#: includes/class-admin.php:149
msgid "Scan WordPress Content"
msgstr "掃描 WordPress 內容"

#: includes/class-admin.php:150
msgid "Scans public posts/pages and attachments, then stores review tasks."
msgstr "掃描公開文章、頁面與附件，並儲存審查工作。"

